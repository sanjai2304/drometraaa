{
    "version": 2,
    "builds": [
          {
                  "src": "frontend/app.py",
                  "use": "@vercel/python"
          }
    ],
    "routes": [
          {
                  "src": "/(.*)",
                  "dest": "frontend/app.py"
          }
    ],
    "functions": {
          "frontend/app.py": {
                  "excludeFiles": "{dataset/**,plots/**,catboost_info/**,train.py,analyze.py}"
          }
    }
}
